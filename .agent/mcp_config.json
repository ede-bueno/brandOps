{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "YOUR_API_KEY"
            ]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        },
        "serena": {
            "command": "oh-my-ag",
            "args": [
                "bridge",
                "http://localhost:9847/mcp"
            ]
        }
    }
}
// setup mcp server in  ~/.gemini\antigravity\mcp_config.json