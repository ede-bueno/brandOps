{
  "name": "brandops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next-dev.js",
    "clean": "node -e \"const fs=require('node:fs'); ['.next','.next-dev','.next-build','tsconfig.tsbuildinfo','tsconfig.typecheck.tsbuildinfo'].forEach((path)=>fs.rmSync(path,{ recursive:true, force:true }));\"",
    "build": "npm run check && node scripts/run-next-build.js",
    "start": "node scripts/start-standalone.js",
    "lint": "next lint",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "check": "npm run type-check && npm run lint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.48.1",
    "@types/papaparse": "^5.5.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.475.0",
    "next": "^15.1.12",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^16.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.1.12",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "supabase": "^2.83.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.57.1"
  }
}
